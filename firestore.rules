rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownLike(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /articleLikes/{articleId} {
      allow read: if true;

      allow create: if signedIn()
        && request.resource.data.keys().hasOnly(['count', 'updatedAt'])
        && request.resource.data.count == 1
        && existsAfter(/databases/$(database)/documents/articleLikes/$(articleId)/users/$(request.auth.uid));

      allow update: if signedIn()
        && request.resource.data.keys().hasOnly(['count', 'updatedAt'])
        && resource.data.keys().hasOnly(['count', 'updatedAt'])
        && request.resource.data.count is int
        && request.resource.data.count >= 0
        && (
          (
            request.resource.data.count == resource.data.count + 1
            && !exists(/databases/$(database)/documents/articleLikes/$(articleId)/users/$(request.auth.uid))
            && existsAfter(/databases/$(database)/documents/articleLikes/$(articleId)/users/$(request.auth.uid))
          )
          ||
          (
            request.resource.data.count == resource.data.count - 1
            && exists(/databases/$(database)/documents/articleLikes/$(articleId)/users/$(request.auth.uid))
            && !existsAfter(/databases/$(database)/documents/articleLikes/$(articleId)/users/$(request.auth.uid))
          )
        );

      allow delete: if false;

      match /users/{uid} {
        allow read: if ownLike(uid);

        allow create: if ownLike(uid)
          && !exists(/databases/$(database)/documents/articleLikes/$(articleId)/users/$(uid))
          && request.resource.data.keys().hasOnly(['uid', 'createdAt'])
          && request.resource.data.uid == uid;

        allow delete: if ownLike(uid)
          && exists(/databases/$(database)/documents/articleLikes/$(articleId)/users/$(uid));

        allow update: if false;
      }
    }
  }
}
